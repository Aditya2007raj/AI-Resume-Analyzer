# ==============================================================================
# Resume Analyzer - .gitignore
# ==============================================================================

# -----------------------------
# Python
# -----------------------------
__pycache__/
*.py[cod]
*$py.class

# -----------------------------
# Virtual Environments
# -----------------------------
.venv/
venv/
env/
ENV/

# -----------------------------
# Environment Variables
# -----------------------------
.env
.env.*
!.env.example

# -----------------------------
# Streamlit
# -----------------------------
.streamlit/secrets.toml

# -----------------------------
# Uploaded Files
# -----------------------------
uploads/
temp/
tmp/

# -----------------------------
# Logs
# -----------------------------
*.log

# -----------------------------
# Build Files
# -----------------------------
build/
dist/
*.egg-info/

# -----------------------------
# IDEs
# -----------------------------
.vscode/
.idea/

# -----------------------------
# Operating System Files
# -----------------------------
.DS_Store
Thumbs.db

# -----------------------------
# Testing
# -----------------------------
.pytest_cache/
.coverage
htmlcov/

# -----------------------------
# Jupyter Notebooks
# -----------------------------
.ipynb_checkpoints/

# -----------------------------
# Type Checkers
# -----------------------------
.mypy_cache/
.pyre/

# -----------------------------
# Misc
# -----------------------------
*.sqlite3
*.db